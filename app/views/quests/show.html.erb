<div class="max-w-lg mx-auto px-4 py-10">

  <%# Status badge e ações %>
  <div class="flex items-center justify-between mb-6">
    <% if @quest.completed? %>
      <span class="text-xs font-semibold bg-green-900/50 text-green-400 px-3 py-1 rounded-full">
        ✓ Concluída
      </span>
    <% else %>
      <span class="text-xs font-semibold bg-indigo-900/50 text-indigo-400 px-3 py-1 rounded-full">
        Em andamento
      </span>
    <% end %>

    <div class="flex gap-3">
      <%= link_to "Editar", edit_quest_path(@quest),
          class: "text-sm text-gray-400 hover:text-white transition-colors" %>
      <%= button_to "Apagar", quest_path(@quest),
          method: :delete,
          form: { data: { turbo_confirm: "Tem certeza? Isso apaga a quest e todos os challenges." } },
          class: "text-sm text-red-400 hover:text-red-300 transition-colors cursor-pointer" %>
    </div>
  </div>

  <h1 class="text-2xl font-bold text-white mb-1"><%= @quest.title %></h1>

  <% if @quest.description.present? %>
    <p class="text-gray-400 mb-6"><%= @quest.description %></p>
  <% end %>

  <%# Progresso geral %>
  <div class="bg-gray-900 rounded-2xl p-6 mb-4">
    <div class="flex justify-between text-sm mb-3">
      <span class="text-gray-400">Progresso</span>
      <span class="text-white font-semibold">
        <%= @quest.progress %> de <%= @quest.total %> challenges
      </span>
    </div>
    <div class="w-full bg-gray-800 rounded-full h-2">
      <div class="bg-indigo-500 h-2 rounded-full transition-all"
           style="width: <%= @quest.progress_percentage %>%"></div>
    </div>
  </div>

  <%# Lista de challenges %>
  <div class="bg-gray-900 rounded-2xl p-6 mb-4">
    <p class="text-sm text-gray-400 mb-4">Challenges</p>

    <% if @quest.challenges.empty? %>
      <p class="text-gray-600 text-sm">Nenhum challenge ainda.</p>
    <% else %>
      <div class="space-y-3">
        <% @quest.challenges.order(created_at: :asc).each do |challenge| %>
          <% if challenge.active? || challenge.completed? || challenge.finished? %>
            <%= link_to challenge_path(challenge),
                class: "block rounded-xl p-4 transition-colors
                        #{challenge.completed? ? 'bg-green-900/20 border border-green-900/30' :
                          challenge.finished? ? 'bg-gray-800/50' : 'bg-gray-800 hover:bg-gray-700'}" do %>
              <div class="flex items-center justify-between">
                <span class="text-sm font-semibold
                             #{challenge.completed? ? 'text-green-400' :
                               challenge.finished? ? 'text-gray-500' : 'text-white'}">
                  <%= challenge.title %>
                </span>
                <% if challenge.completed? %>
                  <span class="text-xs text-green-400">✓</span>
                <% elsif challenge.finished? %>
                  <span class="text-xs text-gray-500">Encerrado</span>
                <% else %>
                  <span class="text-xs text-indigo-400">
                    <%= challenge.progress %>/<%= challenge.duration_days %>
                  </span>
                <% end %>
              </div>
            <% end %>
          <% end %>
        <% end %>
      </div>
    <% end %>

    <%# Botão adicionar próximo challenge %>
    <% if @quest.next_challenge_available? %>
      <div class="mt-4 pt-4 border-t border-gray-800">
        <%= link_to "+ Adicionar próximo challenge",
            new_challenge_path(quest_id: @quest.id),
            class: "text-indigo-400 hover:text-indigo-300 text-sm transition-colors" %>
      </div>
    <% end %>
  </div>

  <%# Reward %>
  <% if @quest.reward.present? %>
    <div class="bg-gray-900 rounded-2xl p-5 mb-4">
      <p class="text-xs text-gray-500 mb-1">Reward da Quest</p>
      <%= link_to reward_path(@quest.reward), class: "flex items-center justify-between" do %>
        <div>
          <p class="text-white font-semibold"><%= @quest.reward.description %></p>
          <p class="text-xs text-gray-500 mt-1">
            <% if @quest.reward.locked? %>
              🔒 Bloqueado — conclua todos os challenges
            <% elsif @quest.reward.unlocked? %>
              🎁 Desbloqueado — pronto para resgatar
            <% else %>
              ✅ Resgatado
            <% end %>
          </p>
        </div>
        <span class="text-gray-600">→</span>
      <% end %>
    </div>
  <% end %>

  <%= link_to "← Voltar", quests_path,
      class: "block text-center text-gray-500 text-sm mt-6 hover:text-gray-300" %>

</div>

