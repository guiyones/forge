<div class="max-w-lg mx-auto px-4 py-10">

  <div class="flex items-center justify-between mb-6">
    <% if @quest.completed? %>
      <span class="text-xs font-semibold px-3 py-1 rounded-full" style="background: rgba(34,197,94,0.15); color: #22C55E;">✓ Concluída</span>
    <% else %>
      <span class="text-xs font-semibold px-3 py-1 rounded-full" style="background: rgba(108,77,255,0.15); color: #6C4DFF;">Em andamento</span>
    <% end %>
    <div class="flex gap-3">
      <%= link_to "Editar", edit_quest_path(@quest), class: "text-sm text-gray-400 hover:text-white transition-colors" %>
      <%= link_to "Apagar", quest_path(@quest),
          data: { turbo_method: :delete, turbo_confirm: "Tem certeza? Isso apaga a jornada e todos os desafios." },
          class: "text-sm hover:text-red-300 transition-colors", style: "color: #f87171;" %>
    </div>
  </div>

  <h1 class="text-2xl font-bold text-white mb-1"><%= @quest.title %></h1>

  <% if @quest.description.present? %>
    <p class="text-gray-400 mb-6"><%= @quest.description %></p>
  <% end %>

  <%# Progresso %>
  <div class="rounded-2xl p-6 mb-4" style="background: #1F2937;">
    <div class="flex justify-between text-sm mb-3">
      <span class="text-gray-400">Progresso</span>
      <span class="font-semibold text-white"><%= @quest.progress %> de <%= @quest.total %> desafios</span>
    </div>
    <div class="w-full rounded-full h-2" style="background: #374151;">
      <div class="h-2 rounded-full transition-all" style="width: <%= @quest.progress_percentage %>%; background: linear-gradient(90deg, #6C4DFF, #22C55E);"></div>
    </div>
  </div>

  <%# Desafios %>
  <div class="rounded-2xl p-6 mb-4" style="background: #1F2937;">
    <p class="text-sm text-gray-400 mb-4">Desafios</p>

    <% if @quest.challenges.empty? %>
      <p class="text-gray-600 text-sm">Nenhum desafio ainda.</p>
    <% else %>
      <div class="space-y-3">
        <% @quest.challenges.order(created_at: :asc).each do |challenge| %>
          <%= link_to challenge_path(challenge),
              class: "evolva-card",
              style: challenge.completed? ? 'background: rgba(34,197,94,0.1); border: 0.5px solid rgba(34,197,94,0.2);' :
                     challenge.active? ? 'background: rgba(108,77,255,0.1); border: 0.5px solid rgba(108,77,255,0.3);' :
                     challenge.paused? ? 'background: #1F2937; border: 0.5px solid #374151;' :
                     challenge.finished? ? 'background: rgba(55,65,81,0.5);' :
                     'background: #374151;' do %>
            <div class="flex items-center justify-between">
              <span class="text-sm font-semibold"
                    style="color: <%= challenge.completed? ? '#22C55E' : challenge.active? ? '#f3f4f6' : '#6b7280' %>;">
                <%= challenge.title %>
              </span>
              <% if challenge.completed? %>
                <span class="text-xs" style="color: #22C55E;">✓</span>
              <% elsif challenge.active? %>
                <span class="text-xs font-semibold px-2 py-0.5 rounded-full" style="background: rgba(108,77,255,0.15); color: #6C4DFF;">🔵 Foco</span>
              <% elsif challenge.paused? %>
                <span class="text-xs text-gray-500">⏸ Pausado</span>
              <% elsif challenge.planned? %>
                <span class="text-xs text-gray-500">Planejado</span>
              <% elsif challenge.finished? %>
                <span class="text-xs text-gray-500">Encerrado</span>
              <% end %>
            </div>
            <% unless challenge.planned? %>
              <div class="flex justify-between mt-2" style="font-size: 11px; color: #6b7280;">
                <span><%= challenge.progress %> / <%= challenge.duration_days %> dias</span>
                <span><%= challenge.progress_percentage %>%</span>
              </div>
            <% end %>
          <% end %>
        <% end %>
      </div>
    <% end %>

    <% if @quest.can_add_challenge? %>
      <div class="mt-4 pt-4" style="border-top: 0.5px solid #374151;">
        <%= link_to "+ Adicionar desafio", new_challenge_path(quest_id: @quest.id),
            class: "text-sm transition-colors", style: "color: #6C4DFF;" %>
      </div>
    <% end %>
  </div>

  <%# Reward %>
  <% if @quest.reward.present? %>
    <div class="rounded-2xl p-5 mb-4" style="background: #1F2937;">
      <p class="text-xs text-gray-500 mb-1">Recompensa da Jornada</p>
      <%= link_to reward_path(@quest.reward), class: "flex items-center justify-between" do %>
        <div>
          <p class="text-white font-semibold"><%= @quest.reward.description %></p>
          <p class="text-xs text-gray-500 mt-1">
            <% if @quest.reward.locked? %>
              🔒 Bloqueado — conclua todos os desafios
            <% elsif @quest.reward.unlocked? %>
              🎁 Desbloqueado — pronto para resgatar
            <% else %>
              ✅ Resgatado
            <% end %>
          </p>
        </div>
        <span class="text-gray-600">→</span>
      <% end %>
    </div>
  <% end %>

  <%= link_to "← Voltar", quests_path, class: "block text-center text-gray-500 text-sm mt-6 hover:text-gray-300" %>
</div>

