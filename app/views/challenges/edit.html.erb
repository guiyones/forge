<div class="min-h-screen flex items-center justify-center px-4">
  <div class="w-full max-w-lg">

    <h1 class="text-2xl font-bold text-white mb-2">Editar Challenge</h1>
    <p class="text-gray-400 mb-8">Você pode editar o título e a descrição.</p>

    <%= form_with model: @challenge, class: "space-y-6" do |f| %>

      <% if @challenge.errors.any? %>
        <div class="bg-red-900/40 text-red-300 rounded-lg px-4 py-3 text-sm">
          <% @challenge.errors.full_messages.each do |msg| %>
            <p><%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <div>
        <%= f.label :title, "Qual é o desafio?", class: "block text-sm text-gray-400 mb-2" %>
        <%= f.text_field :title,
            class: "w-full bg-gray-800 text-white rounded-lg px-4 py-3
                    border border-gray-700 focus:outline-none focus:border-indigo-500",
            placeholder: "ex: 20 dias sem álcool" %>
      </div>

      <div>
        <%= f.label :description, "Por que você está fazendo isso?",
            class: "block text-sm text-gray-400 mb-2" %>
        <%= f.text_area :description,
            class: "w-full bg-gray-800 text-white rounded-lg px-4 py-3
                    border border-gray-700 focus:outline-none focus:border-indigo-500
                    resize-none",
            rows: 3,
            placeholder: "opcional" %>
      </div>

      <%= f.submit "Salvar alterações",
          class: "w-full bg-indigo-600 hover:bg-indigo-500 text-white
                  font-semibold py-3 rounded-lg cursor-pointer transition-colors" %>

    <% end %>

    <%= link_to "← Voltar", challenge_path(@challenge),
        class: "block text-center text-gray-500 text-sm mt-4 hover:text-gray-300" %>

  </div>
</div>
