<div class="max-w-lg mx-auto px-4 py-10">

  <div class="flex items-center justify-between mb-8">
    <h1 class="text-2xl font-bold text-white">Desafios</h1>
    <%= link_to "+ Novo", new_challenge_path,
        class: "text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors bg-[#6C4DFF] hover:bg-[#5A3DE6]" %>
  </div>

  <% if @challenges.empty? %>
    <div class="text-center py-20">
      <p class="text-gray-500 mb-4">Nenhum desafio ainda.</p>
      <%= link_to "Criar seu primeiro desafio →", new_challenge_path,
          style: "color: #6C4DFF;" %>
    </div>
  <% else %>
    <div class="space-y-3">
      <% @challenges.each do |challenge| %>
        <%= link_to challenge_path(challenge), class: "evolva-card" do %>
          <div class="flex items-center justify-between mb-2">
            <h2 class="text-white text-sm font-semibold"><%= challenge.title %></h2>
            <% if challenge.completed? %>
              <span class="text-xs" style="color: #22C55E;">✓ Concluído</span>
            <% elsif challenge.finished? %>
              <span class="text-xs text-gray-500">Encerrado</span>
            <% else %>
              <span class="text-xs" style="color: #6C4DFF;">Em andamento</span>
            <% end %>
          </div>

          <% if challenge.quest.present? %>
            <p class="text-xs text-gray-500 mb-2">Jornada: <span style="color: #6C4DFF;"><%= challenge.quest.title %></span></p>
          <% end %>

          <div class="flex justify-between text-xs text-gray-500 mb-2">
            <span><%= challenge.progress %> de <%= challenge.duration_days %> dias</span>
            <span><%= challenge.progress_percentage %>%</span>
          </div>

          <div class="w-full rounded-full h-1" style="background: #374151;">
            <div class="h-1 rounded-full" style="width: <%= challenge.progress_percentage %>%; background: linear-gradient(90deg, #6C4DFF, #22C55E);"></div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>


