<div class="max-w-lg mx-auto px-4 py-10">

  <div class="flex items-center justify-between mb-8">
    <h1 class="text-2xl font-bold text-white">Seus Challenges</h1>
    <%= link_to "Novo", new_challenge_path,
        class: "bg-indigo-600 hover:bg-indigo-500 text-white
                text-sm font-semibold px-4 py-2 rounded-lg transition-colors" %>
  </div>

  <% if @challenges.empty? %>
    <div class="text-center py-20">
      <p class="text-gray-500 mb-4">Nenhum challenge ainda.</p>
      <%= link_to "Criar seu primeiro desafio", new_challenge_path,
          class: "text-indigo-400 hover:text-indigo-300" %>
    </div>
  <% else %>
    <div class="space-y-3">
      <% @challenges.each do |challenge| %>
        <%= link_to challenge_path(challenge), class: "block bg-gray-900 rounded-2xl p-5 hover:bg-gray-800 transition-colors" do %>
          <div class="flex items-center justify-between mb-3">
            <h2 class="text-white font-semibold"><%= challenge.title %></h2>
            <% if challenge.completed? %>
              <span class="text-xs text-green-400">✓ Concluído</span>
            <% elsif challenge.finished? %>
              <span class="text-xs text-gray-500">Encerrado</span>
            <% else %>
              <span class="text-xs text-indigo-400">Em andamento</span>
            <% end %>
          </div>
          
          <% if challenge.quest.present? %>
            <p class="text-xs text-gray-600 mb-2">↑ Quest: <%= challenge.quest.title %></p>
          <% end %>

          <div class="flex justify-between text-sm text-gray-500 mb-2">
            <span><%= challenge.progress %> de <%= challenge.duration_days %> dias</span>
            <span><%= challenge.progress_percentage %>%</span>
          </div>

          <div class="w-full bg-gray-800 rounded-full h-1">
            <div class="bg-indigo-500 h-1 rounded-full"
                 style="width: <%= challenge.progress_percentage %>%"></div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>

</div>
