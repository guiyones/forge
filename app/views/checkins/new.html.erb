<div class="min-h-screen flex items-center justify-center px-4 mt-4">
  <div class="w-full max-w-lg">

    <div class="text-center mb-10">
      <p class="text-gray-400 text-md font-bold mb-2"><%= @challenge.title %></p>
      <h1 class="text-3xl font-bold text-white">
        Dia <%= @challenge.progress + 1 %> de <%= @challenge.duration_days %>
      </h1>
    </div>

    <%= form_with model: [@challenge, @checkin], class: "space-y-8" do |f| %>

      <div class="text-center">
        <p class="text-gray-400 mb-6">Você fez hoje?</p>
        <button type="submit"
                class="w-48 h-48 rounded-full text-white font-bold text-xl transition-all
                       hover:scale-105 active:scale-95 cursor-pointer shadow-lg"
                style="background: #6C4DFF; box-shadow: 0 8px 32px rgba(108,77,255,0.3);">
          Sim, fiz
        </button>
      </div>
      
      <div>
        <p class="text-gray-400 text-sm text-center mb-3">
        Como foi? <span class="text-gray-600">(opcional)</span>
        </p>
        <input type="hidden" name="checkin[feeling]" id="checkin_feeling" value="">
        <div class="flex gap-3 justify-center" data-controller="feeling">
          <% [["hard", "Difícil"], ["ok", "Ok"], ["easy", "Fácil"]].each do |value, label| %>
            <button type="button"
                    data-feeling-target="option"
                    data-action="click->feeling#select"
                    data-value="<%= value %>"
                    class="px-5 py-2 rounded-full text-sm cursor-pointer transition-all"
                    style="border: 0.5px solid #374151; color: #6b7280; background: transparent;">
                    <%= label %>
            </button>
          <% end %>
        </div>
      </div>

      <div>
        <p class="text-gray-400 text-sm text-center mb-3">
          Alguma nota? <span class="text-gray-600">(opcional)</span>
        </p>
        <%= f.text_area :note,
            class: "w-full rounded-xl px-4 py-3 text-white text-sm resize-none",
            style: "background: #1F2937; border: 0.5px solid #374151;",
            rows: 3,
            placeholder: "Hoje foi difícil mas fiz..." %>
      </div>

    <% end %>

    <%= link_to "← Voltar", challenge_path(@challenge),
        class: "block text-center text-gray-500 text-sm mt-6 mb-6 hover:text-gray-300" %>
  </div>
</div>


