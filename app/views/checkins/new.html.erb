<div class="min-h-screen flex items-center justify-center px-4">
  <div class="w-full max-w-lg">

    <%# Cabeçalho %>
    <div class="text-center mb-10">
      <p class="text-gray-400 text-sm mb-2"><%= @challenge.title %></p>
      <h1 class="text-3xl font-bold text-white">
        Dia <%= @challenge.progress + 1 %> de <%= @challenge.duration_days %>
      </h1>
    </div>

    <%= form_with model: [@challenge, @checkin], class: "space-y-8" do |f| %>

      <%# Camada 1 — O momento (obrigatória) %>
      <div class="text-center">
        <p class="text-gray-400 mb-6">Você fez hoje?</p>
        <button type="submit"
                class="w-48 h-48 rounded-full bg-indigo-600 hover:bg-indigo-500
                       text-white font-bold text-xl transition-all
                       hover:scale-105 active:scale-95 cursor-pointer
                       shadow-lg shadow-indigo-900/50">
          Sim, fiz
        </button>
      </div>

      <%# Camada 2 — Como foi (opcional) %>
      <div>
        <p class="text-gray-400 text-sm text-center mb-3">
          Como foi? <span class="text-gray-600">(opcional)</span>
        </p>
        <div class="flex gap-3 justify-center">
          <% [["hard", "Difícil"], ["ok", "Ok"], ["easy", "Fácil"]].each do |value, label| %>
            <label class="cursor-pointer">
              <%= f.radio_button :feeling, value, class: "sr-only peer", id: "feeling_#{value}" %>
              <span class="block px-5 py-2 rounded-full border border-gray-700
                           text-gray-400 text-sm transition-all
                           peer-checked:border-indigo-500 peer-checked:text-indigo-400
                           peer-checked:bg-indigo-900/30 hover:border-gray-500">
                <%= label %>
              </span>
            </label>
          <% end %>
        </div>
      </div>

      <%# Camada 3 — Nota (opcional) %>
      <div>
        <p class="text-gray-400 text-sm text-center mb-3">
          Alguma nota? <span class="text-gray-600">(opcional)</span>
        </p>
        <%= f.text_area :note,
            class: "w-full bg-gray-800 text-white rounded-xl px-4 py-3
                    border border-gray-700 focus:outline-none focus:border-indigo-500
                    resize-none text-sm",
            rows: 3,
            placeholder: "Hoje foi difícil mas fiz..." %>
      </div>

    <% end %>

    <%= link_to "← Voltar", challenge_path(@challenge),
        class: "block text-center text-gray-500 text-sm mt-6 hover:text-gray-300" %>

  </div>
</div>
