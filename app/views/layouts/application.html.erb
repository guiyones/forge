<style>
  /* Bottom nav */
  .bottom-nav { display: none; }
    @media (max-width: 768px) {
      .bottom-nav { display: flex; position: fixed; bottom: 0; left: 0; right: 0;
                background: #0a0f1a; border-top: 0.5px solid #1f2937;
                justify-content: space-around; padding: 10px 0 20px;
                z-index: 50; }
     }
  .nav-item { display: flex; flex-direction: column; align-items: center;
              gap: 3px; text-decoration: none; color: #6b7280;
              font-size: 10px; font-weight: 500; transition: color 0.15s; }
  .nav-item:hover { color: #f3f4f6; }
  .nav-item.active { color: #818cf8; }
  .nav-icon { font-size: 18px; }
</style>

<!DOCTYPE html>
<html>
  <head>
    <title>Evolva</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#0f172a">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Evolva">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>
    <%= tag.link rel: "apple-touch-icon", href: "/icon-192.png" %>
    <%= tag.link rel: "icon", type: "image/png", href: "/icon-192.png" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <script>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/service-worker.js', { scope: '/' })
      }
    </script>
  </head>
  <body class="bg-gray-950 text-white min-h-screen">

    <% if authenticated? %>
      <nav class="hidden md:flex items-center justify-between px-6 py-4 border-b border-gray-800">
        <%= link_to root_path, class: "flex items-center gap-2" do %>
          <img src="/icon.png?v=2" alt="Evolva" class="w-6 h-6 rounded-lg">
          <span class="font-bold text-lg" style="color: #6C4DFF;">Evolva</span>
        <% end %> 
        <div class="flex items-center gap-6">
          <%= link_to "Home", root_path, class: "text-sm text-gray-400 hover:text-white transition-colors" %>
          <%= link_to "Desafios", challenges_path, class: "text-sm text-gray-400 hover:text-white transition-colors" %>
          <%= link_to "Jornadas", quests_path, class: "text-sm text-gray-400 hover:text-white transition-colors" %>
          <%= link_to "Histórico", history_path, class: "text-sm text-gray-400 hover:text-white transition-colors" %>
          <%= link_to "Como funciona", how_it_works_path, class: "text-sm text-gray-400 hover:text-white transition-colors" %>
        </div>
        <%= button_to "Sair", session_path, method: :delete,
          class: "text-sm text-gray-400 hover:text-white transition-colors cursor-pointer" %>
      </nav>
    <% end %>

    <% if notice %>
      <div class="max-w-lg mx-auto px-4 mt-4">
        <div class="rounded-lg px-4 py-3 text-sm flex items-center justify-between"
             style="background: rgba(34,197,94,0.1); color: #22C55E; border: 0.5px solid rgba(34,197,94,0.2);"
             data-controller="dismissible">
          <span><%= notice %></span>
          <button data-action="click->dismissible#dismiss"
                  class="hover:text-white ml-4 cursor-pointer" style="color: #22C55E;">✕</button>
        </div>
      </div>
    <% end %>

    <% if alert %>
      <div class="max-w-lg mx-auto px-4 mt-4">
        <div class="rounded-lg px-4 py-3 text-sm flex items-center justify-between"
             style="background: rgba(239,68,68,0.1); color: #f87171; border: 0.5px solid rgba(239,68,68,0.2);"
             data-controller="dismissible">
          <span><%= alert %></span>
          <button data-action="click->dismissible#dismiss"
                  class="hover:text-white ml-4 cursor-pointer" style="color: #f87171;">✕</button>
        </div>
      </div>
    <% end %>

    <%= yield %>
  </body>

  <%# Bottom nav mobile %>
  <% if authenticated? %>
    <nav class="bottom-nav">
      <%= link_to root_path, class: "nav-item active" do %>
        <img src="/icon.png?v=2" alt="Evolva" style="width: 24px; height: 24px; border-radius: 6px;">
        <span>Home</span>
      <% end %>
    <%= link_to challenges_path, class: "nav-item" do %>
      <span class="nav-icon">⚔️</span>
      <span>Desafios</span>
    <% end %>
    <%= link_to quests_path, class: "nav-item" do %>
      <span class="nav-icon">📖</span>
      <span>Jornadas</span>
    <% end %>
    <%= link_to history_path, class: "nav-item" do %>
      <span class="nav-icon">📋</span>
      <span>Histórico</span>
    <% end %>
    <%= link_to how_it_works_path, class: "nav-item" do %>
      <span class="nav-icon">❓</span>
      <span>Guia</span>
    <% end %>
  </nav>
<% end %>
</html>

