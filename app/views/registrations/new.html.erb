<div class="min-h-screen flex items-center justify-center">
  <div class="w-full max-w-md px-8 py-10 bg-gray-900 rounded-2xl">

    <h1 class="text-2xl font-bold text-white mb-2">Criar conta</h1>
    <p class="text-gray-400 mb-8">Comece sua primeira jornada</p>

    <%= form_with model: @user, url: registration_path do |f| %>

      <% if @user.errors.any? %>
        <div class="bg-red-900/40 text-red-300 rounded-lg px-4 py-3 mb-6 text-sm">
          <% @user.errors.full_messages.each do |msg| %>
            <p><%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <div class="mb-5">
        <%= f.label :email_address, "Email", class: "block text-sm text-gray-400 mb-2" %>
        <%= f.email_field :email_address,
            class: "w-full bg-gray-800 text-white rounded-lg px-4 py-3
                    border border-gray-700 focus:outline-none
                    focus:border-indigo-500",
            placeholder: "seu@email.com" %>
      </div>

      <div class="mb-5">
        <%= f.label :password, "Senha", class: "block text-sm text-gray-400 mb-2" %>
        <%= f.password_field :password,
            class: "w-full bg-gray-800 text-white rounded-lg px-4 py-3
                    border border-gray-700 focus:outline-none
                    focus:border-indigo-500",
            placeholder: "mínimo 12 caracteres" %>
      </div>

      <div class="mb-8">
        <%= f.label :password_confirmation, "Confirmar senha",
            class: "block text-sm text-gray-400 mb-2" %>
        <%= f.password_field :password_confirmation,
            class: "w-full bg-gray-800 text-white rounded-lg px-4 py-3
                    border border-gray-700 focus:outline-none
                    focus:border-indigo-500",
            placeholder: "repita a senha" %>
      </div>

      <%= f.submit "Criar conta",
          class: "w-full bg-indigo-600 hover:bg-indigo-500 text-white
                  font-semibold py-3 rounded-lg cursor-pointer
                  transition-colors" %>

    <% end %>

    <p class="text-center text-gray-500 text-sm mt-6">
      Já tem conta?
      <%= link_to "Entrar", new_session_path,
          class: "text-indigo-400 hover:text-indigo-300" %>
    </p>

  </div>
</div>


